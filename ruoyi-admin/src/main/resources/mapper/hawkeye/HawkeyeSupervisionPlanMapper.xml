<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hawkeye.supervisionPlan.mapper.HawkeyeSupervisionPlanMapper">
    
    <resultMap type="HawkeyeSupervisionPlan" id="HawkeyeSupervisionPlanResult">
        <result property="planId"    column="plan_id"    />
        <result property="categoryId"    column="category_id"    />
        <result property="categoryName"    column="category_name"    />
        <result property="planName"    column="plan_name"    />
        <result property="planType"    column="plan_type"    />
        <result property="totalDays"    column="total_days"    />
        <result property="description"    column="description"    />
        <result property="difficultyLevel"    column="difficulty_level"    />
        <result property="status"    column="status"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectHawkeyeSupervisionPlanVo">
        select ec.category_name,sp.* from hawkeye_supervision_plan sp
        left join hawkeye_exam_category ec on sp.category_id=ec.category_id
    </sql>

    <select id="selectHawkeyeSupervisionPlanList" parameterType="HawkeyeSupervisionPlan" resultMap="HawkeyeSupervisionPlanResult">
        <include refid="selectHawkeyeSupervisionPlanVo"/>
        <where>  
            <if test="categoryId != null "> and sp.category_id = #{categoryId}</if>
            <if test="planName != null  and planName != ''"> and plan_name like concat('%', #{planName}, '%')</if>
            <if test="planType != null  and planType != ''"> and plan_type = #{planType}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="difficultyLevel != null "> and difficulty_level = #{difficultyLevel}</if>
        </where>
    </select>
    
    <select id="selectHawkeyeSupervisionPlanByPlanId" parameterType="Long" resultMap="HawkeyeSupervisionPlanResult">
        <include refid="selectHawkeyeSupervisionPlanVo"/>
        where plan_id = #{planId}
    </select>

    <insert id="insertHawkeyeSupervisionPlan" parameterType="HawkeyeSupervisionPlan" useGeneratedKeys="true" keyProperty="planId">
        insert into hawkeye_supervision_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="planName != null and planName != ''">plan_name,</if>
            <if test="planType != null and planType != ''">plan_type,</if>
            <if test="totalDays != null">total_days,</if>
            <if test="description != null">description,</if>
            <if test="difficultyLevel != null">difficulty_level,</if>
            <if test="status != null">status,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="planName != null and planName != ''">#{planName},</if>
            <if test="planType != null and planType != ''">#{planType},</if>
            <if test="totalDays != null">#{totalDays},</if>
            <if test="description != null">#{description},</if>
            <if test="difficultyLevel != null">#{difficultyLevel},</if>
            <if test="status != null">#{status},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateHawkeyeSupervisionPlan" parameterType="HawkeyeSupervisionPlan">
        update hawkeye_supervision_plan
        <trim prefix="SET" suffixOverrides=",">
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="planName != null and planName != ''">plan_name = #{planName},</if>
            <if test="planType != null and planType != ''">plan_type = #{planType},</if>
            <if test="totalDays != null">total_days = #{totalDays},</if>
            <if test="description != null">description = #{description},</if>
            <if test="difficultyLevel != null">difficulty_level = #{difficultyLevel},</if>
            <if test="status != null">status = #{status},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where plan_id = #{planId}
    </update>

    <delete id="deleteHawkeyeSupervisionPlanByPlanId" parameterType="Long">
        delete from hawkeye_supervision_plan where plan_id = #{planId}
    </delete>

    <delete id="deleteHawkeyeSupervisionPlanByPlanIds" parameterType="String">
        delete from hawkeye_supervision_plan where plan_id in 
        <foreach item="planId" collection="array" open="(" separator="," close=")">
            #{planId}
        </foreach>
    </delete>
</mapper>